{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Graphite Envelope Draft",
  "type": "object",
  "required": ["protocol", "kind", "created_at", "payload"],
  "properties": {
    "protocol": { "type": "string", "pattern": "^graphite/[0-9]+\\.[0-9]+$" },
    "kind": { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9_.]*$" },
    "created_at": { "type": "string", "format": "date-time" },
    "gate": { "type": "object" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
